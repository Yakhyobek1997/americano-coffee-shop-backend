<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Signup | Modern</title>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap"
    />
    <style>
      body {
        margin: 0;
        font-family: "Poppins", sans-serif;
        background: linear-gradient(135deg, #f8fafc, #e0f7fa);
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
      }

      .signup-container {
        background: white;
        padding: 30px 40px;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 500px;
      }

      .signup-header {
        text-align: center;
        margin-bottom: 24px;
      }

      .signup-header h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 600;
        color: #333;
      }

      .form-group {
        margin-bottom: 18px;
      }

      label {
        font-weight: 500;
        display: block;
        margin-bottom: 6px;
      }

      input[type="text"],
      input[type="password"] {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
      }

      input[type="text"]:focus,
      input[type="password"]:focus {
        border-color: #2196f3;
      }

      .form-row {
        display: flex;
        gap: 16px;
      }

      .form-row .form-group {
        flex: 1;
      }

      .upload-section {
        margin: 20px 0;
      }

      .upload-preview {
        width: 100%;
        border-radius: 10px;
        margin-bottom: 10px;
      }

     .file-box {
  display: flex;
  align-items: stretch; /* YANGI — bo‘ylarini tenglashtiradi */
}

.upload-name {
  flex: 1;
  padding: 12px;
  border: 1px solid #ccc;
  border-radius: 8px 0 0 8px;
  font-size: 14px;
  height: 45px; /* YANGI — barqaror balandlik */
  box-sizing: border-box;
}

.file-box label {
  background: #2196f3;
  color: white;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border-radius: 0 8px 8px 0;
  height: 45px; /* YANGI — input bilan bir xil */
  font-size: 14px;
  white-space: nowrap;
}

      input[type="file"] {
        display: none;
      }

      .signup-btn {
        width: 100%;
        padding: 14px;
        border: none;
        background-color: #4caf50;
        color: white;
        font-size: 16px;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.3s ease;
      }

      .signup-btn:hover {
        background-color: #43a047;
      }

      .alt-link {
        text-align: center;
        margin-top: 16px;
        font-size: 14px;
      }
    </style>
  </head>
  <body>
    <form
      class="signup-container"
      action="/admin/signup"
      method="POST"
      enctype="multipart/form-data"
    >
      <div class="signup-header">
        <h2>Americano</h2>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="memberNick">Restaurant *</label>
          <input type="text" name="memberNick" placeholder="e.g. FoodBox" />
        </div>

        <div class="form-group">
          <label for="memberPhone">Phone *</label>
          <input type="text" name="memberPhone" placeholder="e.g. 123-4567" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="memberPassword">Password *</label>
          <input type="password" name="memberPassword" />
        </div>
        <div class="form-group">
          <label for="confirmPassword">Repeat Password *</label>
          <input type="password" name="confirmPassword" />
        </div>
      </div>

      <div class="upload-section">
        <label class="media-text">Upload Restaurant Image</label>
        <div class="file-box">
          <input
            class="upload-name"
            id="file-name-display"
            value="No file selected"
            disabled
          />
          <label for="input-file">Upload</label>
          <input
            type="file"
            id="input-file"
            name="memberImage"
            onchange="updateFileName()"
          />
        </div>
      </div>

      <input name="memberType" value="RESTAURANT" hidden />

      <button class="signup-btn" type="submit">Create Account</button>

      <div class="alt-link">
        Already have an account? <a href="/admin/login">Login</a>
      </div>
    </form>
  </body>
</html>