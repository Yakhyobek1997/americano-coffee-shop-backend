<%- include('includes/header') %>
<link rel="stylesheet" type="text/css" href="/css/users.css" />

<body>
  <div class="users-container">
    <% if (!member) { %>
      <!-- Navigation for non-authenticated users -->
      <div class="navigation-menu">
        <ul class="nav justify-content-center">
          <li class="nav-item"><a class="nav-link active" href="/admin/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/signup">Sign Up</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/login">Login</a></li>
        </ul>
      </div>

      <!-- Access restriction message -->
      <div class="users-frame">
        <div class="board">
          <div class="header-name" style="font-size: 32px; color: #fff;">
            🚫 Please log in to view users!
          </div>
        </div>
      </div>
    <% } else { %>
      <!-- Navigation for authenticated users -->
      <div class="navigation-menu">
        <ul class="nav justify-content-center">
          <li class="nav-item"><a class="nav-link active" href="/admin/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/product/all">Menu</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/user/all">Users</a></li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/logout" onclick="return confirm('Do you really want to logout?')">Logout</a>
          </li>
        </ul>
      </div>

      <!-- Users table -->
      <div class="users-frame">
        <div class="board">
          <div class="user-table">
            <span class="header-name"> All Registered Users</span>
            <table class="table table-hover table-bordered table-striped">
              <thead class="thead-dark">
                <tr>
                  <th>#</th>
                  <th>Username</th>
                  <th>Phone</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% users.map(function(user, index) { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td><%= user.memberNick %></td>
                    <td><%= user.memberPhone %></td>
                    <td>
                      <select class="spec-select member-status" id="<%= user._id %>">
                        <option value="ACTIVE" <%= user.memberStatus === 'ACTIVE' ? 'selected' : '' %>>ACTIVE</option>
                        <option value="BLOCK" <%= user.memberStatus === 'BLOCK' ? 'selected' : '' %>>BLOCK</option>
                        <option value="DELETE" <%= user.memberStatus === 'DELETE' ? 'selected' : '' %>>DELETE</option>
                      </select>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <script type="text/javascript" src="/js/users.js"></script>
</body>

<%- include('includes/footer') %>
